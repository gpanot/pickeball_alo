generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Venue {
  id               String          @id @default(cuid())
  name             String
  address          String
  lat              Float
  lng              Float
  phone            String?
  hours            String?
  rating           Float?
  reviewCount      Int             @default(0)
  priceMin         Int?
  priceMax         Int?
  tags             String[]
  amenities        String[]
  images           String[]
  facebookUrl      String?
  instagramUrl     String?
  tiktokUrl        String?
  googleUrl        String?
  adminPin         String?
  hasMemberPricing Boolean         @default(false)
  /// When true, player UI shows 30-minute bookable slots at half the table's hourly rate. When false, hourly slots at full hourly rate (DB still stores 30-minute rows).
  use30MinSlots    Boolean         @default(true)
  /// AloBo venue slug extracted from datlich.alobo.vn URL (e.g. "sport_65th_street_pickleball").
  aloboSlug        String?
  courts           Court[]
  bookings         Booking[]
  pricingTables    PricingTable[]
  dateOverrides    DateOverride[]
  payments         VenuePayment[]
  coachLinks       CoachCourtLink[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model VenuePayment {
  id                    String  @id @default(cuid())
  venueId               String
  venue                 Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bank                  String
  accountName           String
  accountNumber         String
  qrImageUrl            String?
  /// 6-digit BIN for VietQR (img.vietqr.io)
  bankBin               String?
  isDefaultForDynamicQr Boolean @default(false)
  sortOrder             Int     @default(0)

  @@index([venueId])
}

/// Structured pricing: time bands with walk-in (and optional member) VND prices.
model PricingTable {
  id        String   @id @default(cuid())
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name      String
  dayTypes  String[]
  rows      Json
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId])
}

/// Force a calendar date to use holiday/weekend (or custom) pricing resolution.
model DateOverride {
  id      String  @id @default(cuid())
  venueId String
  venue   Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  date    String
  dayType String
  note    String?

  @@unique([venueId, date])
  @@index([venueId])
}

model Court {
  id          String     @id @default(cuid())
  venueId     String
  venue       Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name        String
  note        String?
  isAvailable Boolean    @default(true)
  /// AloBo court identifier (e.g. "san_1", "san_2").
  aloboId     String?
  slots       TimeSlot[]

  @@index([venueId])
}

model TimeSlot {
  id          String @id @default(cuid())
  courtId     String
  court       Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)
  date        String
  time        String
  price       Int
  memberPrice Int?
  isBooked    Boolean @default(false)

  @@unique([courtId, date, time])
  @@index([courtId, date])
}

model Booking {
  id           String   @id @default(cuid())
  orderId      String   @unique @default(cuid())
  venueId      String
  venue        Venue    @relation(fields: [venueId], references: [id])
  venueName    String
  venuePhone   String?
  venueAddress String?
  userId       String
  userName     String
  userPhone    String
  date         String
  slots        Json
  totalPrice   Int
  notes        String?
  adminNote    String?
  reviewedAt           DateTime?
  reviewedBy           String?
  status               String    @default("pending")
  paymentSubmittedAt   DateTime?
  paymentConfirmedAt   DateTime?
  paymentNote          String?
  paymentProofUrl      String?
  /// Auto-cancel deadline: booking is cancelled if proof is not uploaded by this time.
  paymentDeadline      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([venueId])
}

model UserProfile {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  passwordHash String?
  savedVenues String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Coach Marketplace Models ───────────────────────────────────────────────

model Coach {
  id                  String              @id @default(cuid())
  name                String
  phone               String              @unique
  email               String?             @unique
  passwordHash        String
  phoneVerified       Boolean             @default(false)
  photo               String?
  bio                 String?
  certifications      String[]
  specialties         String[]
  languages           String[]
  focusLevels         String[]
  groupSizes          String[]
  experienceBand      String?
  yearsExperience     Int?
  responseHint        String?
  ratingOverall       Float?
  ratingOnTime        Float?
  ratingFriendly      Float?
  ratingProfessional  Float?
  ratingRecommend     Float?
  reviewCount         Int                 @default(0)
  isActive            Boolean             @default(true)
  isProfilePublic     Boolean             @default(true)

  subscriptionPlan    String              @default("trial")
  subscriptionExpires DateTime?
  trialBookingsUsed   Int                 @default(0)

  hourlyRate1on1      Int
  hourlyRateGroup     Int?
  maxGroupSize        Int                 @default(4)

  cancellationHours   Int                 @default(24)
  creditExpiryDays    Int                 @default(90)

  bankName            String?
  bankAccountName     String?
  bankAccountNumber   String?
  bankBin             String?

  /// Incremented each time coach flags ANY session; gate at 3
  paymentFlagCount    Int                 @default(0)

  courtLinks          CoachCourtLink[]
  availability        CoachAvailability[]
  sessions            CoachSession[]
  creditPacks         CreditPack[]
  credits             Credit[]
  reviews             CoachReview[]
  invitesReceived     CoachVenueInvite[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model CoachCourtLink {
  id        String  @id @default(cuid())
  coachId   String
  coach     Coach   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  venueId   String
  venue     Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  courtIds  String[]
  isActive  Boolean @default(true)

  @@unique([coachId, venueId])
  @@index([coachId])
  @@index([venueId])
}

model CoachAvailability {
  id        String  @id @default(cuid())
  coachId   String
  coach     Coach   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  dayOfWeek Int?
  date      String?
  startTime String
  endTime   String
  venueId   String
  isBlocked Boolean @default(false)

  @@index([coachId])
  @@index([coachId, dayOfWeek])
  @@index([coachId, date])
}

model CoachSession {
  id              String               @id @default(cuid())
  coachId         String
  coach           Coach                @relation(fields: [coachId], references: [id])
  venueId         String
  venueName       String
  courtName       String?
  date            String
  startTime       String
  endTime         String
  sessionType     String
  maxPlayers      Int                  @default(1)
  /// confirmed | completed | canceled
  status          String               @default("confirmed")

  coachFee        Int
  courtFee        Int
  totalPerPlayer  Int

  paymentMethod   String?
  paymentStatus   String               @default("pending")

  /// Per-session: when coach flagged payment not received on THIS session
  paymentFlaggedAt DateTime?

  slotIds         String[]

  participants    SessionParticipant[]

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([coachId])
  @@index([coachId, date])
  @@index([venueId])
}

model SessionParticipant {
  id              String       @id @default(cuid())
  sessionId       String
  session         CoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId          String
  userName        String
  userPhone       String
  amountDue       Int
  paymentMethod   String?
  paymentStatus   String       @default("pending")
  paymentProofUrl String?
  paidAt          DateTime?
  creditId        String?

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model CreditPack {
  id              String  @id @default(cuid())
  coachId         String
  coach           Coach   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name            String
  creditCount     Int
  price           Int
  discountPercent Int?
  isActive        Boolean @default(true)

  @@index([coachId])
}

model Credit {
  id               String   @id @default(cuid())
  coachId          String
  coach            Coach    @relation(fields: [coachId], references: [id])
  userId           String
  userName         String
  userPhone        String
  creditPackId     String?
  totalCredits     Int
  remainingCredits Int
  pricePerCredit   Int
  totalPaid        Int
  paymentProofUrl  String?
  paymentStatus    String   @default("pending")
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([coachId, userId])
  @@index([userId])
}

model CoachReview {
  id                 String   @id @default(cuid())
  coachId            String
  coach              Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  sessionId          String?
  userId             String
  userName           String
  ratingOnTime       Int
  ratingFriendly     Int
  ratingProfessional Int
  ratingRecommend    Int
  ratingOverall      Float
  comment            String?
  isPublic           Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([coachId])
  @@index([userId])
}

model CoachVenueInvite {
  id          String    @id @default(cuid())
  coachId     String
  coach       Coach     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  venueId     String
  invitedBy   String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@unique([coachId, venueId])
  @@index([coachId])
  @@index([venueId])
}
