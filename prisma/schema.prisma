generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Venue {
  id               String          @id @default(cuid())
  name             String
  address          String
  lat              Float
  lng              Float
  phone            String?
  hours            String?
  rating           Float?
  reviewCount      Int             @default(0)
  priceMin         Int?
  priceMax         Int?
  tags             String[]
  amenities        String[]
  images           String[]
  facebookUrl      String?
  instagramUrl     String?
  tiktokUrl        String?
  googleUrl        String?
  adminPin         String?
  hasMemberPricing Boolean         @default(false)
  /// When true, player UI shows 30-minute bookable slots at half the table's hourly rate. When false, hourly slots at full hourly rate (DB still stores 30-minute rows).
  use30MinSlots    Boolean         @default(true)
  /// AloBo venue slug extracted from datlich.alobo.vn URL (e.g. "sport_65th_street_pickleball").
  aloboSlug        String?
  courts           Court[]
  bookings         Booking[]
  pricingTables    PricingTable[]
  dateOverrides    DateOverride[]
  payments         VenuePayment[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model VenuePayment {
  id                    String  @id @default(cuid())
  venueId               String
  venue                 Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bank                  String
  accountName           String
  accountNumber         String
  qrImageUrl            String?
  /// 6-digit BIN for VietQR (img.vietqr.io)
  bankBin               String?
  isDefaultForDynamicQr Boolean @default(false)
  sortOrder             Int     @default(0)

  @@index([venueId])
}

/// Structured pricing: time bands with walk-in (and optional member) VND prices.
model PricingTable {
  id        String   @id @default(cuid())
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name      String
  dayTypes  String[]
  rows      Json
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId])
}

/// Force a calendar date to use holiday/weekend (or custom) pricing resolution.
model DateOverride {
  id      String  @id @default(cuid())
  venueId String
  venue   Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  date    String
  dayType String
  note    String?

  @@unique([venueId, date])
  @@index([venueId])
}

model Court {
  id          String     @id @default(cuid())
  venueId     String
  venue       Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name        String
  note        String?
  isAvailable Boolean    @default(true)
  /// AloBo court identifier (e.g. "san_1", "san_2").
  aloboId     String?
  slots       TimeSlot[]

  @@index([venueId])
}

model TimeSlot {
  id          String @id @default(cuid())
  courtId     String
  court       Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)
  date        String
  time        String
  price       Int
  memberPrice Int?
  isBooked    Boolean @default(false)

  @@unique([courtId, date, time])
  @@index([courtId, date])
}

model Booking {
  id           String   @id @default(cuid())
  orderId      String   @unique @default(cuid())
  venueId      String
  venue        Venue    @relation(fields: [venueId], references: [id])
  venueName    String
  venuePhone   String?
  venueAddress String?
  userId       String
  userName     String
  userPhone    String
  date         String
  slots        Json
  totalPrice   Int
  notes        String?
  adminNote    String?
  reviewedAt           DateTime?
  reviewedBy           String?
  status               String    @default("pending")
  paymentSubmittedAt   DateTime?
  paymentConfirmedAt   DateTime?
  paymentNote          String?
  paymentProofUrl      String?
  /// Auto-cancel deadline: booking is cancelled if proof is not uploaded by this time.
  paymentDeadline      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([venueId])
}

model UserProfile {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  savedVenues String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
