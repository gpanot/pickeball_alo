{
  "manifest_version": 3,
  "name": "Alobo Court Scraper",
  "version": "3.2",
  "description": "Captures AES key before SES lockdown and decrypts venue data",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["https://datlich.alobo.vn/*", "https://*.alobo.vn/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://datlich.alobo.vn/*"],
      "js": ["hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://datlich.alobo.vn/*"],
      "js": ["content_bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "32": "icon.png" }
  }
}
