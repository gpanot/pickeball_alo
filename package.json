{
  "name": "pickeball_alo",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "postinstall": "node scripts/prisma-generate-ensure-env.mjs",
    "build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:deploy": "prisma migrate deploy",
    "db:sync-pricing": "npx tsx prisma/sync-pricing-from-json.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "test": "jest --runInBand",
    "test:phase1": "jest --runInBand coaches.test",
    "test:phase2": "jest --runInBand sessions.test",
    "test:phase3": "jest --runInBand credits.test",
    "test:phase6": "jest --runInBand reviews.test"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "next": "^15.1.0",
    "prisma": "^6.19.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.15",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
